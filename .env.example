# The bridge's own HTTP port (Railway sets PORT automatically)
PORT=8080

# Alfred API on FK Vercel
ALFRED_API_URL=https://fractionkings.com
ALFRED_BRIDGE_SECRET=<same value set on Vercel>

# WhatsApp group JID that Alfred is in. Discovered on first run via console output.
ALFRED_GROUP_JID=<GROUP_ID>@g.us

# Alfred's own WhatsApp phone number (E.164 digits only, no plus). Used by the
# tag-only response filter to detect self-mentions. Leave empty for boot; the
# filter still works via text patterns and reply-to-Alfred detection.
ALFRED_PHONE=

# Founding king phone numbers (E.164 no plus). Match Vercel's WHATSAPP_KING_*.
KING_TYLER=15551234567
KING_ANTONIOS=15551234567
KING_MORGAN=15551234567
KING_ANDREW=15551234567

# Feature flags
BRIDGE_LOG_LEVEL=info
BRIDGE_AUTH_PATH=./auth-state
